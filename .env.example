# EC Growth Studio AI — Environment Variables (server-side only)
#
# このファイルは Vercel Functions (`api/bq/*`) が参照するサーバー側 env のキー一覧。
# 値の実体はリポジトリにコミットしない。実値は Vercel Env (Sensitive) または
# ローカル開発環境の `.env.local` に設定する（`.env.local` は git 管理外）。
#
# Phase 3A の現状:
# - `/api/bq/health` と `/api/bq/orders-daily` は BQ_MOCK_MODE=true でデモ動作する
# - 実 GCP 接続は未稼働。Vercel Env / GCP / dataset / SA はまだ設定していない
# - 上司デモは BQ_MOCK_MODE=true のみで完結する設計
#
# !!! セキュリティ上の絶対ルール !!!
# - サービスアカウント JSON ファイル本体は絶対にコミットしない
# - private_key / client_email を含む文字列を docs / コードに直書きしない
# - フロントエンド (VITE_*) には GCP 認証情報を載せない

# GCP プロジェクトID（例: insight-studio-prod）
GCP_PROJECT_ID=

# サービスアカウント JSON を base64 エンコードした 1 行文字列
# 生成例:
#   macOS / Linux: base64 -w0 service-account.json
#   Windows PowerShell:
#     [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
GCP_SERVICE_ACCOUNT_JSON_BASE64=

# 参照する dataset 名（Phase 3A は Insight Studio 既存 GCP に同居）
BQ_DATASET=ec_growth_demo

# dataset のロケーション（既存 Insight Studio dataset と一致させる）
BQ_LOCATION=asia-northeast1

# CORS 許可 Origin（カンマ区切り）。Vercel Preview / Production の URL を列挙する
# 例: https://ec-growth-studio-ai.vercel.app,https://ec-growth-studio-ai-git-main.vercel.app
ALLOWED_ORIGINS=

# 1 リクエストあたりの最大期間（日数）。orders-daily の from/to バリデーションに使う
MAX_QUERY_DAYS=370

# BigQuery デモ Mode（GCP 実接続前の検証ステップ用）
# - true / 1: `/api/bq/*` は GCP に接続せず mock response を返す（mode:"mock" を含む）
# - 未設定 / その他: 既存の env (GCP_PROJECT_ID 等) を使う実接続を試みる
#   ただし env 未設定時は health は CONFIG_MISSING、orders-daily は NOT_IMPLEMENTED で安全に失敗
# - 認証情報・課金は一切発生しない。ローカル開発 / 上司デモ用フラグ
# - VITE_ プレフィックスを付けない（フロントには露出させない）
BQ_MOCK_MODE=true
